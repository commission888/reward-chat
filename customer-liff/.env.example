VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# Dev-only convenience: real LIFF id/shop id normally come from the
# ?liff_id=&shop_id= query params LINE appends when opening the LIFF app.
VITE_LIFF_MOCK=true
VITE_DEV_LIFF_ID=
VITE_DEV_SHOP_ID=11111111-1111-1111-1111-111111111111
# Pick your own random value here and mirror it in supabase/.env.local as
# REGISTER_CUSTOMER_DEV_BYPASS_TOKEN. Never set the server-side var on a
# deployed/linked project — doing so lets anyone impersonate any customer.
VITE_DEV_BYPASS_TOKEN=
