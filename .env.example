# Root .env.example — copy relevant keys into merchant-app/.env, customer-liff/.env,
# and set edge function secrets via `supabase secrets set --env-file supabase/.env.local`

# --- Shared Supabase project values (local dev defaults from `supabase start`) ---
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Edge Function secrets (supabase/.env.local, never committed) ---
OPENAI_API_KEY=
QR_SIGNING_SECRET=change-me-to-a-long-random-string

# --- customer-liff dev-only convenience (real LIFF id comes from ?liff_id= query param per shop) ---
VITE_LIFF_MOCK=true
VITE_DEV_LIFF_ID=
VITE_DEV_SHOP_ID=
